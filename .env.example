# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Perplexity
PERPLEXITY_API_KEY=your-perplexity-api-key

# Apollo.io
APOLLO_API_KEY=your-apollo-api-key

# Instantly.ai
INSTANTLY_API_KEY=your-instantly-api-key
INSTANTLY_WEBHOOK_SECRET=your-webhook-secret-here

# Instantly Sequence IDs (set these after creating sequences in Instantly)
INSTANTLY_SEQ_MFG_VP_OPS=
INSTANTLY_SEQ_MFG_MAINTENANCE=
INSTANTLY_SEQ_MFG_PLANT_MANAGER=
INSTANTLY_SEQ_MFG_DIRECTOR_OPS=
INSTANTLY_SEQ_MFG_GENERAL=
INSTANTLY_SEQ_FB_VP_OPS=
INSTANTLY_SEQ_FB_PLANT_MANAGER=
INSTANTLY_SEQ_FB_VP_QUALITY=
INSTANTLY_SEQ_FB_DIR_QUALITY=

# Resend
RESEND_API_KEY=your-resend-api-key

# Webhook
WEBHOOK_SECRET=your-webhook-secret

# App
LOG_LEVEL=INFO
BATCH_SIZE=10

# Outreach send gate
# Set to true ONLY after mailbox warm-up is complete in Instantly.
# When false (default), approved drafts are staged but never pushed to Instantly.
# The scheduler checks this every 30 minutes automatically.
SEND_ENABLED=false

# Auth
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Stripe billing
# Get these from Stripe Dashboard → Products after creating the ProspectIQ products.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_BASE_URL=https://app.prospectiq.ai

# Stripe price IDs — monthly
STRIPE_PRICE_STARTER=price_...   # $1,500/mo
STRIPE_PRICE_GROWTH=price_...    # $3,500/mo
STRIPE_PRICE_SCALE=price_...     # $7,500/mo
STRIPE_PRICE_API=price_...       # $0.05/company (metered)

# Stripe price IDs — annual (15% discount)
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_SCALE_ANNUAL=price_...

# Voyage AI — text embeddings for semantic memory search (free tier: 200M tokens/month)
# Sign up at https://www.voyageai.com (no credit card required for free tier).
# When not set, memory store uses PostgreSQL full-text search as fallback.
VOYAGE_API_KEY=

# Unipile — LinkedIn automation
# Register at unipile.com, connect your LinkedIn account, then set these.
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=              # LinkedIn account ID in Unipile
UNIPILE_DSN=api4.unipile.com:13453
UNIPILE_WEBHOOK_SECRET=          # Set in both .env and Unipile dashboard webhook settings

# Sentry — error tracking and performance monitoring
# Create a project at sentry.io, select Python/FastAPI, copy the DSN.
SENTRY_DSN=                      # https://...@sentry.io/...
SENTRY_ENVIRONMENT=production    # production | staging | development
SENTRY_TRACES_SAMPLE_RATE=0.1   # Fraction of transactions to trace (0.0–1.0)

# Google OAuth — configure in Supabase Dashboard → Authentication → Providers → Google
# No env vars needed here — credentials are stored in Supabase, not in the backend.
# Steps:
#   1. Create OAuth credentials at console.cloud.google.com (OAuth 2.0 Client ID)
#   2. Add callback URL: https://<your-project>.supabase.co/auth/v1/callback
#   3. Enable Google provider in Supabase Dashboard and paste Client ID + Secret
#   4. In frontend, call: supabase.auth.signInWithOAuth({ provider: 'google' })
